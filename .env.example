# ── API Server ────────────────────────────────────────────────
PORT=3001
NODE_ENV=production

# MySQL (e.g. XAMPP's bundled MySQL/MariaDB) — required for portfolio,
# watchlist, settings, and user accounts. XAMPP's default root user has no
# password, and MySQL runs on port 3306.
DATABASE_URL=mysql://root:@localhost:3306/nse_pulse

# Signs session cookies (JWT). Use a long random string in production,
# e.g. `openssl rand -hex 32`.
JWT_SECRET=change-this-to-a-long-random-string

# Initial admin account — auto-created on first boot if no admin exists yet
# (along with the default roles/permissions, on a brand new database).
# Change the password (or these values) before deploying to production.
ADMIN_EMAIL=admin@marketpulse.ai
ADMIN_PASSWORD=Admin@123

# Optional: Upstox API (users configure this from the Settings page)
# UPSTOX_API_KEY=
# UPSTOX_API_SECRET=
