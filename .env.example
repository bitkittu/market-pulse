# ── API Server ────────────────────────────────────────────────
PORT=3001
NODE_ENV=production

# MongoDB — required for portfolio, watchlist, settings, and user accounts.
# Use a MongoDB Atlas connection string (or any MongoDB URI). If your password
# contains reserved URL characters (e.g. # @ / :) percent-encode them.
MONGODB_URI=mongodb+srv://USER:PASSWORD@your-cluster.mongodb.net/?retryWrites=true&w=majority

# Database name to use inside the cluster (the URI above need not include one).
MONGODB_DB=nse_pulse

# Signs session cookies (JWT). Use a long random string in production,
# e.g. `openssl rand -hex 32`.
JWT_SECRET=change-this-to-a-long-random-string

# Initial admin account — auto-created on first boot if no admin exists yet
# (along with the default roles, on a brand new database).
# Change the password (or these values) before deploying to production.
ADMIN_EMAIL=team@trading.brandmars.com
ADMIN_PASSWORD=Admin@123

# Public base URL, used to build password-reset links. Falls back to the
# request host if unset. Set this in production, e.g. https://trading.brandmars.com
# APP_BASE_URL=https://trading.brandmars.com

# Password-reset email (SMTP). Until these are set, reset links are only logged
# on the server. Set SHOW_RESET_LINK=true to also return the link in the API
# response for testing (leave OFF in production once email works).
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=no-reply@trading.brandmars.com
# SHOW_RESET_LINK=false

# Optional: Upstox API (users configure this from the Settings page)
# UPSTOX_API_KEY=
# UPSTOX_API_SECRET=
